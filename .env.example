# Configuración del entorno de la plataforma PA_TH
# Copia este archivo a `.env` y edita los valores correspondientes.

# URL de conexión a la Base de Datos
# Si se deja vacío o se comenta, el sistema usará SQLite local automáticamente (data/th_platform.sqlite)
# Ejemplo para PostgreSQL local o remoto (compatible con Render/Heroku):
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/db_path_unitropico

# Otras configuraciones de Streamlit (Opcional)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
